{
    "name": "my-cinema-list",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite --host 127.0.0.1",
        "build": "vite build",
        "build:cloudflare": "vite build --base=/",
        "build:gh-pages": "vite build --base=/Cinema_List/",
        "preview": "vite preview --host 127.0.0.1",
        "pages:dev": "npm run build:cloudflare && npx wrangler pages dev dist",
        "deploy": "npm run deploy:gh-pages",
        "deploy:cloudflare": "npm run build:cloudflare && npx wrangler pages deploy dist --project-name cinemalist",
        "deploy:gh-pages": "npm run build:gh-pages && gh-pages -d dist"
    },
    "dependencies": {
        "flowbite": "^2.5.2",
        "lucide-vue-next": "^0.468.0",
        "vue": "^3.5.13"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^5.2.1",
        "autoprefixer": "^10.4.20",
        "gh-pages": "^6.3.0",
        "postcss": "^8.4.49",
        "tailwindcss": "^3.4.17",
        "vite": "^6.0.5"
    }
}
